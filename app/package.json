{
  "name": "app",
  "type": "module",
  "scripts": {
    "css:build": "npx @tailwindcss/cli -i style.css -o public/style.css --minify",
    "css:watch": "npx @tailwindcss/cli -i style.css -o public/style.css --watch",
    "start": "npm run css:build && elm-pages dev",
    "build": "npm run css:build && elm-pages build",
    "test": "npx playwright test"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@tailwindcss/cli": "4.2.2",
    "@types/node": "25.5.0",
    "daisyui": "5.5.19",
    "elm-codegen": "0.6.3",
    "elm-optimize-level-2": "0.3.5",
    "elm-pages": "3.3.0",
    "lamdera": "0.19.1-1.4.0",
    "vite": "6.4.1"
  },
  "dependencies": {
    "tailwindcss": "4.2.2"
  }
}
